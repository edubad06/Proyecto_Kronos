<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- AVATAR + NOMBRE ENCABEZADO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="24dp"
            android:paddingBottom="32dp">

            <TextView
                android:id="@+id/tvNombreHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/nom_usuari_defecte"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/primary_text" />

            <TextView
                android:id="@+id/tvRolHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/rol_defecte"
                android:textSize="13sp"
                android:textColor="@color/secondary_text" />

        </LinearLayout>

        <!-- DIVIDER -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="24dp" />

        <!-- SECCIÓN: INFORMACIÓN DE CUENTA -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/compta_info"
            android:textSize="11sp"
            android:textColor="@color/secondary_text"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp" />

        <!-- CAMPO: NOMBRE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/card_background"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:layout_marginBottom="1dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nom"
                    android:textSize="11sp"
                    android:textColor="@color/secondary_text" />

                <TextView
                    android:id="@+id/tvNombre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textSize="15sp"
                    android:textColor="@color/primary_text" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnEditarNombre"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_more_vert"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/desc_editar_nom" />

        </LinearLayout>

        <!-- CAMPO: EMAIL -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/card_background"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:layout_marginBottom="1dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/correu_electronic"
                    android:textSize="11sp"
                    android:textColor="@color/secondary_text" />

                <TextView
                    android:id="@+id/tvEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textSize="15sp"
                    android:textColor="@color/primary_text" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnEditarEmail"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_more_vert"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/desc_editar_correu" />

        </LinearLayout>

        <!-- CAMPO: CONTRASEÑA -->
        <Button
            android:id="@+id/btnCambiarContrasenya"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="@string/btn_cambiar_contrasenya"
            android:textSize="15sp"
            android:backgroundTint="@color/card_background"
            android:strokeColor="#D32F2F"
            android:textColor="#D32F2F"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />


        <!-- SECCIÓN: EXCAVACIÓN -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/excavacio_maj"
            android:textSize="11sp"
            android:textColor="@color/secondary_text"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp" />

        <!-- CAMPO: EXCAVACIÓN -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card_background"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:layout_marginBottom="1dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nom"
                android:textSize="11sp"
                android:textColor="@color/secondary_text" />


            <TextView
                android:id="@+id/tvExcavacio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="15sp"
                android:textColor="@color/primary_text" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card_background"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:layout_marginBottom="1dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/codi_intervencio_hint"
                android:textSize="11sp"
                android:textColor="@color/secondary_text" />


            <TextView
                android:id="@+id/tvCodiEx"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="15sp"
                android:textColor="@color/primary_text" />
        </LinearLayout>

        <!-- CAMPO: ROL -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card_background"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:layout_marginBottom="40dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/rol"
                android:textSize="11sp"
                android:textColor="@color/secondary_text" />

            <TextView
                android:id="@+id/tvRol"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="15sp"
                android:textColor="@color/primary_text" />
        </LinearLayout>

        <Button
            android:id="@+id/btnGuardarCambis"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/btn_guardar_cambis"
            android:textSize="15sp"
            android:textColor="#D32F2F"
            android:backgroundTint="@color/card_background"
            android:strokeColor="#D32F2F"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <Button
            android:id="@+id/btnTornarEnrera"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="@string/btn_tornar_enrera"
            android:textSize="15sp"
            android:textColor="#D32F2F"
            android:backgroundTint="@color/card_background"
            android:strokeColor="#D32F2F"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
    </LinearLayout>

</ScrollView>